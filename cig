#!/usr/bin/env python3

import sys
import os
import re
import io
import json
import shutil
import zipfile
import tempfile
import threading
import requests
import subprocess
from datetime import datetime
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
EXTRACT_JS = SCRIPT_DIR / "extract.js"
HISTORY_FILE = Path.home() / ".local" / "share" / "cig-cli" / "history.json"

TMDB_API_KEY = os.environ.get("TMDB_API_KEY", "")
SUBDL_API_KEY = os.environ.get("SUBDL_API_KEY", "")
TMDB_BASE = "https://api.themoviedb.org/3"

HEADERS = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 Chrome/120.0 Safari/537.36",
}


def die(msg):
    print(f"\033[31m[error]\033[0m {msg}", file=sys.stderr)
    sys.exit(1)


def info(msg):
    print(f"\033[90m[cig] {msg}\033[0m")


# --- TMDB ---

def search_series(query):
    if not TMDB_API_KEY:
        die("TMDB_API_KEY not set. Export it: export TMDB_API_KEY=your_key")
    r = requests.get(f"{TMDB_BASE}/search/tv",
        params={"api_key": TMDB_API_KEY, "query": query, "language": "en-US"}, timeout=10)
    r.raise_for_status()
    return r.json().get("results", [])


def get_seasons(tmdb_id):
    r = requests.get(f"{TMDB_BASE}/tv/{tmdb_id}",
        params={"api_key": TMDB_API_KEY, "language": "en-US"}, timeout=10)
    r.raise_for_status()
    return [s for s in r.json().get("seasons", []) if s["season_number"] > 0]


def get_episodes(tmdb_id, season_number):
    r = requests.get(f"{TMDB_BASE}/tv/{tmdb_id}/season/{season_number}",
        params={"api_key": TMDB_API_KEY, "language": "en-US"}, timeout=10)
    r.raise_for_status()
    return r.json().get("episodes", [])


# --- Watch history ---

def load_history():
    if HISTORY_FILE.exists():
        try:
            return json.loads(HISTORY_FILE.read_text())
        except Exception:
            return {}
    return {}


def save_history(tmdb_id, show_name, season, episode):
    HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
    history = load_history()
    history[str(tmdb_id)] = {
        "show_name": show_name,
        "season": season,
        "episode": episode,
        "updated": datetime.now().isoformat(),
    }
    HISTORY_FILE.write_text(json.dumps(history, indent=2))


def get_history(tmdb_id):
    return load_history().get(str(tmdb_id))


# --- UI ---

FZF_AVAILABLE = subprocess.run(["which", "fzf"], capture_output=True).returncode == 0


def pick(options, label_fn, header=""):
    labels = [label_fn(item) for item in options]

    if FZF_AVAILABLE:
        fzf_input = "\n".join(labels)
        cmd = ["fzf", "--reverse", "--height=50%", "--border=rounded",
               "--color=prompt:cyan,pointer:yellow,hl:yellow,hl+:yellow",
               "--prompt=  ", "--pointer=▶"]
        if header:
            cmd += ["--header", header]
        try:
            result = subprocess.run(cmd, input=fzf_input, capture_output=True, text=True)
            if result.returncode == 0:
                selected = result.stdout.strip()
                idx = labels.index(selected)
                return options[idx]
            else:
                die("No selection made")
        except FileNotFoundError:
            pass

    # fallback: numbered list
    if header:
        print(f"\033[90m{header}\033[0m")
    for i, label in enumerate(labels):
        print(f"  \033[33m{i+1}\033[0m) {label}")
    print()
    try:
        choice = int(input("Pick: ")) - 1
        if 0 <= choice < len(options):
            return options[choice]
    except (ValueError, KeyboardInterrupt):
        pass
    die("Invalid choice")


# --- Stream extraction ---

def get_player_urls(tmdb_id, season, episode):
    session = requests.Session()

    # provider 1: vidlink.pro — autoplay, no click needed
    yield f"https://vidlink.pro/tv/{tmdb_id}/{season}/{episode}"

    # provider 2: vidsrc.me — cloudnestra hash directly in page
    try:
        url = f"https://vidsrc.me/embed/tv?tmdb={tmdb_id}&season={season}&episode={episode}"
        r = session.get(url, headers={**HEADERS, "Referer": "https://vidsrc.me/"}, timeout=10)
        hashes = re.findall(r'cloudnestra\.com/rcp/([A-Za-z0-9_\-]+)', r.text)
        for h in hashes[:2]:
            yield f"https://cloudnestra.com/rcp/{h}"
    except requests.RequestException:
        pass

    # provider 3: vidsrc.to → vsembed.ru → cloudnestra
    try:
        embed_url = f"https://vidsrc.to/embed/tv/{tmdb_id}/{season}/{episode}"
        r = session.get(embed_url, headers={**HEADERS, "Referer": "https://vidsrc.to/"}, timeout=10)
        srcs = re.findall(r'src="((?:https?:)?//vsembed\.ru/embed/[^"]+)"', r.text)
        for src in srcs:
            iframe_url = "https:" + src if src.startswith("//") else src
            try:
                r2 = session.get(iframe_url, headers={**HEADERS, "Referer": embed_url}, timeout=10)
                hashes = re.findall(r'data-hash="([^"]+)"', r2.text)
                for h in hashes[:2]:
                    yield f"https://cloudnestra.com/rcp/{h}"
            except requests.RequestException:
                continue
    except requests.RequestException:
        pass


def extract_stream(player_url):
    info(f"opening player: {player_url[:60]}...")
    proc = subprocess.Popen(
        ["node", str(EXTRACT_JS), player_url],
        stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
    )

    def drain_stderr():
        for line in proc.stderr:
            info(line.rstrip())
    threading.Thread(target=drain_stderr, daemon=True).start()

    stream_url = proc.stdout.readline().strip()
    cookie_line = proc.stdout.readline().strip()
    cookie_file = cookie_line if cookie_line else None

    if not stream_url:
        proc.wait()
        return None, None, None

    return stream_url, cookie_file, proc


# --- Subtitles ---

def get_subtitles(tmdb_id, season, episode):
    if not SUBDL_API_KEY:
        return None
    try:
        r = requests.get(
            "https://api.subdl.com/api/v1/subtitles",
            params={
                "api_key": SUBDL_API_KEY,
                "tmdb_id": tmdb_id,
                "season_number": season,
                "episode_number": episode,
                "languages": "EN",
                "type": "tv",
            },
            timeout=10,
        )
        subs = [s for s in r.json().get("subtitles", []) if s.get("language") == "EN"]
        if not subs:
            return None

        for s in subs[:6]:
            info(f"sub available: {s.get('release_name') or s.get('name') or s.get('url')}")

        WEB_TAGS = ["WEB", "WEBRip", "WEBDL", "WEB-DL", "AMZN", "NF", "DSNP"]

        def is_web(s):
            return any(t.upper() in (s.get("release_name") or "").upper() for t in WEB_TAGS)

        def is_ep_specific(s):
            name = (s.get("release_name") or "").upper()
            # has explicit episode marker: S01E01, 3x10, etc.
            return bool(re.search(r'S\d{2}E\d{2}|\d+X\d{2}', name)) or s.get("full_season") is False and not re.search(r'S\d{2}\.', name)

        ep_specific = [s for s in subs if is_ep_specific(s)]
        season_packs = [s for s in subs if not is_ep_specific(s)]

        preferred = (
            next((s for s in ep_specific if is_web(s)), None)
            or next(iter(ep_specific), None)
            or next((s for s in season_packs if is_web(s)), None)
            or subs[0]
        )
        info(f"sub selected: {preferred.get('release_name') or preferred.get('name') or preferred.get('url')}")

        zip_url = "https://dl.subdl.com" + preferred["url"]
        zip_data = None
        for attempt in range(3):
            try:
                zip_data = requests.get(zip_url, headers=HEADERS, timeout=20).content
                break
            except requests.RequestException:
                if attempt == 2:
                    return None
        if not zip_data:
            return None

        tmp = tempfile.NamedTemporaryFile(
            suffix=".srt", delete=False,
            prefix=f"cig_{tmdb_id}_s{season}e{episode}_"
        )

        if zip_data[:2] == b'PK':  # zip magic bytes
            with zipfile.ZipFile(io.BytesIO(zip_data)) as z:
                srt_files = [n for n in z.namelist() if n.lower().endswith(".srt")]
                if not srt_files:
                    tmp.close()
                    os.unlink(tmp.name)
                    return None
                ep_str = f"{episode:02d}"
                # try progressively looser patterns
                match = (
                    next((n for n in srt_files if re.search(rf"[Ee]{ep_str}[^0-9]", os.path.basename(n))), None)
                    or next((n for n in srt_files if re.search(rf"[Ee]{ep_str}$", os.path.basename(n).rsplit(".", 1)[0])), None)
                    or next((n for n in srt_files if re.search(rf"(^|[^0-9])0*{episode}([^0-9]|$)", os.path.basename(n))), None)
                    or srt_files[0]
                )
                info(f"subtitle file selected: {os.path.basename(match)} (from {len(srt_files)} in zip)")
                content = z.read(match)
                # strip UTF-8 BOM
                if content.startswith(b'\xef\xbb\xbf'):
                    content = content[3:]
                tmp.write(content)
        else:
            content = zip_data
            if content.startswith(b'\xef\xbb\xbf'):
                content = content[3:]
            tmp.write(content)

        tmp.close()

        # validate: must have a real SRT timestamp
        content = Path(tmp.name).read_bytes()
        if not re.search(rb'\d{2}:\d{2}:\d{2}[,\.]\d{3} *-->', content):
            info(f"subtitle invalid (first 120 bytes: {content[:120]})")
            os.unlink(tmp.name)
            return None

        return tmp.name
    except Exception as e:
        info(f"subtitles unavailable: {e}")
        return None


# --- Playback ---

def resolve_stream_url(url):
    """Bypass vidlink proxy: extract direct CDN URL and the referer header."""
    from urllib.parse import urlparse, parse_qs, unquote
    try:
        parsed = urlparse(url)
        qs = parse_qs(parsed.query)

        referer = None
        headers_raw = qs.get("headers", [None])[0]
        if headers_raw:
            h = json.loads(headers_raw)
            referer = h.get("referer") or h.get("origin")

        host = qs.get("host", [None])[0]
        if host:
            path = unquote(parsed.path.replace("/proxy", "", 1))
            url = host + path

        return url, referer or "https://vidlink.pro/"
    except Exception:
        return url, "https://vidlink.pro/"


def sync_subtitles(stream_url, sub_file, cookie_file):
    """Auto-sync subtitle timing using ffsubsync + mpv audio extraction."""
    if not sub_file or not shutil.which("ffsubsync"):
        return sub_file

    resolved_url, referer = resolve_stream_url(stream_url)
    origin = referer.rstrip("/")
    ref_audio = sub_file.replace(".srt", "_ref.wav")
    synced = sub_file.replace(".srt", "_synced.srt")

    info("syncing subtitles to stream audio (~30s)...")
    try:
        mpv_cmd = [
            "mpv", resolved_url,
            "--no-video", "--length=120",
            f"--referrer={referer}",
            f"--http-header-fields=Origin: {origin},Referer: {referer}",
            "--user-agent=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 Chrome/120.0 Safari/537.36",
            "--no-ytdl", "--quiet",
            "--ao=pcm", f"--ao-pcm-file={ref_audio}",
        ]
        if cookie_file:
            mpv_cmd += ["--cookies", f"--cookies-file={cookie_file}"]
        subprocess.run(mpv_cmd, capture_output=True, timeout=90)

        if not Path(ref_audio).exists() or Path(ref_audio).stat().st_size == 0:
            info("sync: could not extract reference audio, skipping")
            return sub_file

        result = subprocess.run(
            ["ffsubsync", ref_audio, "-i", sub_file, "-o", synced],
            capture_output=True, timeout=60
        )
        if result.returncode == 0 and Path(synced).exists():
            info("subtitles synced")
            os.unlink(sub_file)
            return synced
        info("sync: ffsubsync failed, using unsynced subtitle")
    except Exception as e:
        info(f"sync error: {e}")
    finally:
        try:
            os.unlink(ref_audio)
        except OSError:
            pass
    return sub_file


def play(stream_url, title, sub_file=None, cookie_file=None):
    print(f"\n\033[32m[cig] playing:\033[0m {title}\n")

    stream_url, referer = resolve_stream_url(stream_url)
    origin = referer.rstrip("/")

    cmd = [
        "mpv",
        "--force-media-title=" + title,
        f"--referrer={referer}",
        f"--http-header-fields=Origin: {origin},Referer: {referer}",
        "--user-agent=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 Chrome/120.0 Safari/537.36",
        "--slang=en",
        "--hls-bitrate=max",
        "--no-ytdl",
        "--demuxer-lavf-o=reconnect=1,reconnect_streamed=1,reconnect_delay_max=5",
    ]
    if cookie_file:
        cmd += ["--cookies", f"--cookies-file={cookie_file}"]
    if sub_file:
        cmd.append(f"--sub-file={sub_file}")
        info("english subtitles loaded")
    cmd.append(stream_url)
    try:
        subprocess.run(cmd)
    except FileNotFoundError:
        die("mpv not found. Install it: pacman -S mpv")


def stream_episode(tmdb_id, show_name, season_number, episode):
    ep_num = episode["episode_number"]
    ep_name = episode.get("name", "")
    title = f"{show_name} S{season_number:02d}E{ep_num:02d} — {ep_name}"

    stream_url = None
    cookie_file = None
    browser_proc = None

    for player_url in get_player_urls(tmdb_id, season_number, ep_num):
        url, cf, proc = extract_stream(player_url)
        if url:
            stream_url, cookie_file, browser_proc = url, cf, proc
            break
        if proc:
            proc.terminate()
            try:
                proc.wait(timeout=3)
            except subprocess.TimeoutExpired:
                proc.kill()

    if not stream_url:
        die("Could not extract stream. All providers failed.")

    if SUBDL_API_KEY:
        info("fetching subtitles...")
    sub_file = get_subtitles(tmdb_id, season_number, ep_num)
    sub_file = sync_subtitles(stream_url, sub_file, cookie_file)

    play(stream_url, title, sub_file, cookie_file)

    # terminate browser now that mpv has exited
    if browser_proc and browser_proc.poll() is None:
        browser_proc.terminate()
        try:
            browser_proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            browser_proc.kill()

    for tmp in [sub_file, cookie_file]:
        if tmp:
            try:
                os.unlink(tmp)
            except OSError:
                pass


# --- Main ---

def main():
    print("\033[1m\033[36m cig-cli\033[0m — stream series in your terminal\n")

    query = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else input("Search series: ").strip()
    if not query:
        die("No query provided")

    info(f"searching for '{query}'...")
    print()
    results = search_series(query)
    if not results:
        die("No results found")

    show = pick(results, lambda s: f"{s['name']} ({s.get('first_air_date','?')[:4]})", header="Select show")
    tmdb_id = show["id"]
    show_name = show["name"]

    # check watch history
    last = get_history(tmdb_id)
    if last:
        ep_label = f"S{last['season']:02d}E{last['episode']:02d}"
        try:
            answer = input(f"\n\033[33m[history]\033[0m Continue from {ep_label}? [Y/n] ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            answer = "y"

        if answer not in ("n", "no"):
            seasons = get_seasons(tmdb_id)
            episodes = get_episodes(tmdb_id, last["season"])
            current_episode = next((e for e in episodes if e["episode_number"] == last["episode"]), episodes[0])
            current_episodes = episodes
            current_season_number = last["season"]

            while True:
                stream_episode(tmdb_id, show_name, current_season_number, current_episode)
                current_season_number, current_episodes, current_episode = advance_episode(
                    tmdb_id, show_name, seasons, current_season_number, current_episodes, current_episode
                )
                if current_episode is None:
                    break
            return

    info("fetching seasons...")
    print()
    seasons = get_seasons(tmdb_id)
    if not seasons:
        die("No seasons found")

    season = pick(seasons, lambda s: f"Season {s['season_number']} ({s['episode_count']} episodes)", header="Select season")
    season_number = season["season_number"]

    info("fetching episodes...")
    print()
    episodes = get_episodes(tmdb_id, season_number)
    if not episodes:
        die("No episodes found")

    episode = pick(episodes, lambda e: f"E{e['episode_number']:02d} — {e.get('name','')}", header="Select episode")

    current_episodes = episodes
    current_season_number = season_number
    current_episode = episode

    while True:
        stream_episode(tmdb_id, show_name, current_season_number, current_episode)
        current_season_number, current_episodes, current_episode = advance_episode(
            tmdb_id, show_name, seasons, current_season_number, current_episodes, current_episode
        )
        if current_episode is None:
            break


def advance_episode(tmdb_id, show_name, seasons, current_season_number, current_episodes, current_episode):
    ep_num = current_episode["episode_number"]
    next_ep = next((e for e in current_episodes if e["episode_number"] == ep_num + 1), None)

    if not next_ep:
        next_season = next((s for s in seasons if s["season_number"] == current_season_number + 1), None)
        if not next_season:
            print("\n\033[90m[cig] no more episodes.\033[0m")
            return current_season_number, current_episodes, None
        next_episodes = get_episodes(tmdb_id, next_season["season_number"])
        if not next_episodes:
            return current_season_number, current_episodes, None
        next_ep = next_episodes[0]
        current_episodes = next_episodes
        current_season_number = next_season["season_number"]

    ep_label = f"S{current_season_number:02d}E{next_ep['episode_number']:02d} — {next_ep.get('name', '')}"

    # save next episode to history — regardless of Y/N, next unwatched is next_ep
    save_history(tmdb_id, show_name, current_season_number, next_ep["episode_number"])

    try:
        answer = input(f"\n\033[33m[next]\033[0m {ep_label}  [Y/n] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        return current_season_number, current_episodes, None

    if answer in ("n", "no"):
        return current_season_number, current_episodes, None

    return current_season_number, current_episodes, next_ep


if __name__ == "__main__":
    main()
